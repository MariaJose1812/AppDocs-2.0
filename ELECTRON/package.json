{
  "name": "sgd-conadeh",
  "version": "1.0.0",
  "description": "Sistema de Gestión Documental — CONADEH",
  "main": "main.js",
  "author": "Unidad de Infotecnología — CONADEH",
  "license": "UNLICENSED",
  "private": true,

  "scripts": {
    "dev":          "electron .",
    "build:web":    "cd ../FRONTEND && npx expo export -p web --output-dir ../ELECTRON/dist",
    "dist":         "npm run build:web && electron-builder --win portable",
    "dist:win":     "npm run build:web && electron-builder --win",
    "dist:dir":     "npm run build:web && electron-builder --dir"
  },

  "build": {
    "appId":       "hn.conadeh.sgd",
    "productName": "Sistema Gestión Documental",
    "copyright":   "CONADEH — Unidad de Infotecnología",

    "directories": {
      "output":    "release",
      "buildResources": "assets"
    },

    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "assets/**/*",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "dist",
        "to":   "dist",
        "filter": ["**/*"]
      },
      {
        "from": "../BACKEND",
        "to":   "BACKEND"
      }
    ],

    "asar": true,

    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon":            "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },

    "portable": {
      "artifactName": "SGD-CONADEH-${version}.exe",
      "requestExecutionLevel": "user"
    },

    "nsis": {
      "oneClick":        false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon":   "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "artifactName":    "SGD-CONADEH-Setup-${version}.exe"
    }
  },

  "devDependencies": {
    "electron":         "^40.2.1",
    "electron-builder": "^26.7.0"
  }
}