{
  "name": "electron",
  "version": "1.0.0",
  "description": "Sistema de Gestión Documental CONADEH",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:web": "expo export --platform web",
    "build:prod": "npm run build:web && electron-builder --win portable",
    "pack": "electron-packager . CONADEH-Sistema --platform=win32 --arch=x64 --out=release --overwrite"
  },
  "build": {
    "appId": "com.conadeh.gestion",
    "productName": "CONADEH Gestión Documental",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "assets/**/*",
      "dist/**/*"
    ],
    "asar": true,
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "CONADEH-Sistema-${version}.exe"
    }
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0"
  }
}
