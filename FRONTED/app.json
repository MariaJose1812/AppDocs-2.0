{
  "expo": {
    "name": "Garant",
    "slug": "FRONTED",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/it.png",
    "scheme": "fronted",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#092d66",
        "foregroundImage": "./assets/images/it.png",
        "monochromeImage": "./assets/images/logoCompleto.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mariajose1812.FRONTED",
      "usesCleartextTraffic": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logoInfo.jpeg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-asset",
      "expo-mail-composer"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b5e58412-2189-464c-960f-47b0e84119dc"
      }
    }
  }
}
